Thumbs.db
Desktop.ini
.DS_Store

# IDE/editor folders
.vscode/
.idea/

# Logs
*.log

# Coverage reports
.coverage
coverage.xml
htmlcov/

# Docker
*.pid
docker-compose.override.yml

# Scripts (binaries or OS-specific)
scripts/*.sh
scripts/*.bat

# Miscellaneous
*.swp
*.swo
*.bak
*.tmp
